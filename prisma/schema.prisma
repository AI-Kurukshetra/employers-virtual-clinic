generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  PROVIDER
  EMPLOYER_ADMIN
  SUPER_ADMIN
}

enum AppointmentType {
  VIDEO
  AUDIO
  CHAT
  ASYNC
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum CycleFlow {
  LIGHT
  MEDIUM
  HEAVY
}

enum PrescriptionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum LabStatus {
  ORDERED
  SAMPLE_COLLECTED
  PROCESSING
  RESULTED
  REVIEWED
}

enum LabProvider {
  LABCORP
  QUEST
  OTHER
}

enum CarePlanStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum EmployerPlan {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum ClaimStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  DENIED
  PAID
}

enum ReferralUrgency {
  ROUTINE
  URGENT
  EMERGENT
}

enum ReferralStatus {
  SENT
  ACCEPTED
  DECLINED
  SCHEDULED
  COMPLETED
}

enum AssessmentType {
  PHQ9
  GAD7
  EDINBURGH
  CUSTOM
}

enum MessageType {
  TEXT
  FILE
  IMAGE
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  role          Role
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  patient       Patient?
  provider      Provider?
  employerAdmin EmployerAdmin?
  notifications Notification[]
  sentMessages  Message[]        @relation("MessageSender")
  accounts      Account[]
  sessions      Session[]
}

model Patient {
  id                      String                   @id @default(cuid())
  userId                  String                   @unique
  dateOfBirth             DateTime
  phoneNumber             String
  address                 Json
  emergencyContact        Json
  insuranceId             String?
  insuranceProvider       String?
  medicalHistory          Json?
  allergies               String[]
  medications             String[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments            Appointment[]
  symptomLogs             SymptomLog[]
  cycleTracks             CycleTrack[]
  prescriptions           Prescription[]
  labResults              LabResult[]
  carePlans               CarePlan[]
  pregnancyRecords        PregnancyRecord[]
  mentalHealthAssessments MentalHealthAssessment[]
  fertilityData           FertilityData[]
  referrals               Referral[]
  insuranceClaims         InsuranceClaim[]
  conversations           Conversation[]
}

model Provider {
  id                      String                   @id @default(cuid())
  userId                  String                   @unique
  specialty               String
  licenseNumber           String
  licenseState            String
  npiNumber               String
  languages               String[]
  bio                     String?
  availability            Json
  rating                  Float                    @default(0)
  totalReviews            Int                      @default(0)
  acceptingPatients       Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments            Appointment[]
  prescriptions           Prescription[]
  carePlans               CarePlan[]
  sentReferrals           Referral[]               @relation("ReferringProvider")
  insuranceClaims         InsuranceClaim[]
  mentalHealthAssessments MentalHealthAssessment[]
  conversations           Conversation[]
}

model Conversation {
  id            String    @id @default(cuid())
  patientId     String
  providerId    String
  subject       String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider      Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@unique([patientId, providerId])
  @@index([lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  messageType    MessageType  @default(TEXT)
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Appointment {
  id             String            @id @default(cuid())
  patientId      String
  providerId     String
  type           AppointmentType
  status         AppointmentStatus @default(SCHEDULED)
  scheduledAt    DateTime
  duration       Int
  chiefComplaint String?
  notes          String?
  recordingUrl   String?
  videoRoomId    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  patient        Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider       Provider          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  prescriptions  Prescription[]
  labResults     LabResult[]
  referrals      InsuranceClaim[]

  @@index([providerId, scheduledAt])
  @@index([status])
}

model SymptomLog {
  id        String   @id @default(cuid())
  patientId String
  date      DateTime
  symptoms  Json
  mood      Int
  energy    Int
  sleep     Float
  pain      Int
  notes     String?
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model CycleTrack {
  id          String    @id @default(cuid())
  patientId   String
  periodStart DateTime
  periodEnd   DateTime?
  cycleLength Int?
  ovulationDate DateTime?
  symptoms    String[]
  flow        CycleFlow
  notes       String?
  createdAt   DateTime  @default(now())
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model Prescription {
  id               String             @id @default(cuid())
  patientId        String
  providerId       String
  appointmentId    String?
  medication       String
  dosage           String
  frequency        String
  refills          Int
  refillsRemaining Int
  pharmacyId       String?
  pharmacyName     String?
  status           PrescriptionStatus @default(ACTIVE)
  startDate        DateTime
  endDate          DateTime?
  instructions     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  patient          Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider         Provider           @relation(fields: [providerId], references: [id], onDelete: Cascade)
  appointment      Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([status])
}

model LabResult {
  id            String      @id @default(cuid())
  patientId     String
  appointmentId String?
  testName      String
  testCode      String
  status        LabStatus   @default(ORDERED)
  orderedAt     DateTime
  resultedAt    DateTime?
  results       Json?
  normalRanges  Json?
  isAbnormal    Boolean     @default(false)
  labProvider   LabProvider @default(OTHER)
  createdAt     DateTime    @default(now())
  patient       Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
}

model CarePlan {
  id         String         @id @default(cuid())
  patientId  String
  providerId String
  title      String
  condition  String
  goals      Json
  milestones Json
  status     CarePlanStatus @default(ACTIVE)
  startDate  DateTime
  endDate    DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  patient    Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider   Provider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model Employer {
  id                   String          @id @default(cuid())
  name                 String
  domain               String          @unique
  contactEmail         String
  plan                 EmployerPlan
  employeeCount        Int
  billingEmail         String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  ssoEnabled           Boolean         @default(false)
  ssoConfig            Json?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  employerAdmins       EmployerAdmin[]
  insuranceClaims      InsuranceClaim[]
}

model EmployerAdmin {
  id         String   @id @default(cuid())
  userId     String   @unique
  employerId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
}

model InsuranceClaim {
  id             String      @id @default(cuid())
  patientId      String
  providerId     String
  appointmentId  String
  employerId     String?
  claimNumber    String      @unique
  status         ClaimStatus @default(SUBMITTED)
  serviceDate    DateTime
  diagnosisCodes String[]
  procedureCodes String[]
  billedAmount   Float
  allowedAmount  Float
  paidAmount     Float
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  patient        Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider       Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  employer       Employer?   @relation(fields: [employerId], references: [id], onDelete: SetNull)

  @@index([status])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  body        String
  isRead      Boolean   @default(false)
  metadata    Json?
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id                  String          @id @default(cuid())
  patientId           String
  referringProviderId String
  specialtyNeeded     String
  urgency             ReferralUrgency
  status              ReferralStatus  @default(SENT)
  notes               String?
  createdAt           DateTime        @default(now())
  patient             Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  referringProvider   Provider        @relation("ReferringProvider", fields: [referringProviderId], references: [id], onDelete: Cascade)
}

model FertilityData {
  id             String   @id @default(cuid())
  patientId      String
  date           DateTime
  basalBodyTemp  Float?
  lhSurge        Boolean
  cervicalMucus  String?
  intercourse    Boolean
  medications    Json?
  notes          String?
  createdAt      DateTime @default(now())
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model PregnancyRecord {
  id            String   @id @default(cuid())
  patientId     String
  lmp           DateTime
  dueDate       DateTime
  weeksAlong    Int
  appointments  Json?
  symptoms      Json?
  weight        Float?
  bloodPressure Json?
  notes         String?
  createdAt     DateTime @default(now())
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model MentalHealthAssessment {
  id             String         @id @default(cuid())
  patientId      String
  assessmentType AssessmentType
  responses      Json
  score          Int
  severity       String
  completedAt    DateTime
  providerId     String?
  patient        Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider       Provider?      @relation(fields: [providerId], references: [id], onDelete: SetNull)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
